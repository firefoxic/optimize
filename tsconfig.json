{
	"$schema": "https://www.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": [
			"ESNext",
			"DOM",
		],
		"types": [
			"node"
		],
		"outDir": "./dist",
		"rootDir": "./src",
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"declaration": true,
		"noEmitOnError": true,
		"resolveJsonModule": true,
		"isolatedDeclarations": true,
	},
	"include": [
		"src/**/*",
	],
	"exclude": [
		"node_modules",
		"dist",
	]
}
