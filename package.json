{
	"name": "@firefoxic/optimize",
	"description": "Optimize all frontend graphic assets or all images in specific directory.",
	"version": "5.2.2",
	"license": "MIT",
	"author": {
		"name": "Sergey Artemov",
		"email": "firefoxic.dev@gmail.com"
	},
	"homepage": "https://github.com/firefoxic/optimize#readme",
	"bugs": {
		"url": "https://github.com/firefoxic/optimize/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/firefoxic/optimize.git"
	},
	"bin": {
		"optimize": "dist/bin/cli.js"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/lib/index.js",
			"types": "./dist/lib/index.d.ts"
		}
	},
	"files": [
		"./dist/"
	],
	"engines": {
		"node": ">=22.18"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=26.4",
			"onFail": "download"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.9",
			"onFail": "download"
		}
	},
	"dependencies": {
		"ico-endec": "^0.1.6",
		"meow": "^14.1.0",
		"sharp": "^0.35.3",
		"svgo": "^4.0.1"
	},
	"scripts": {
		"help": "make help"
	},
	"devDependencies": {
		"@firefoxic/oxlint-config": "^0.4.0",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/ui": "4.1.9",
		"oxlint": "^1.72.0",
		"tsdown": "^0.22.3",
		"typescript": "^7.0.1-rc",
		"vitest": "^4.1.9"
	},
	"keywords": [
		"optimize",
		"image",
		"icon",
		"favicon",
		"vector",
		"svg",
		"convert",
		"raster",
		"webp",
		"avif",
		"ico",
		"prepare",
		"frontend"
	]
}
